# Firebase — https://console.firebase.google.com
# Project Settings → Your apps → Web app → config nusxalang

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Firebase Console sozlash (Google login uchun):
# 1. Authentication → Sign-in method → Google → Enable
# 2. Authentication → Settings → Authorized domains → localhost qo'shing
# 3. Firestore Database → Create → Rules → firestore.rules faylini deploy qiling
